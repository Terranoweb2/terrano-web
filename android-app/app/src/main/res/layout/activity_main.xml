<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0f172a">

    <!-- Top Bar (hidden by default on Home, visible for Search/Browser) -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:background="#1e293b"
        android:visibility="gone">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Retour"
            android:tint="#94a3b8"
            android:scaleType="centerInside"
            android:padding="7dp" />

        <ImageButton
            android:id="@+id/btnForward"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:src="@drawable/ic_forward"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Avancer"
            android:tint="#94a3b8"
            android:scaleType="centerInside"
            android:padding="7dp" />

        <EditText
            android:id="@+id/urlBar"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/url_bar_bg"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textColor="#f1f5f9"
            android:textColorHint="#64748b"
            android:textSize="13sp"
            android:hint="Rechercher ou entrer une adresse"
            android:singleLine="true"
            android:imeOptions="actionGo"
            android:inputType="textUri"
            android:selectAllOnFocus="true" />

        <ImageButton
            android:id="@+id/btnRefresh"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:src="@drawable/ic_refresh"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Actualiser"
            android:tint="#94a3b8"
            android:scaleType="centerInside"
            android:padding="7dp" />

        <ImageButton
            android:id="@+id/btnHome"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:src="@drawable/ic_home"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Accueil"
            android:tint="#10b981"
            android:scaleType="centerInside"
            android:padding="7dp" />
    </LinearLayout>

    <!-- Progress bar -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:progressDrawable="@drawable/progress_bar"
        android:max="100"
        android:visibility="gone" />

    <!-- WebView with swipe refresh -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <WebView
            android:id="@+id/webView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#1e293b"
        app:itemIconTint="@color/bottom_nav_color"
        app:itemTextColor="@color/bottom_nav_color"
        app:labelVisibilityMode="labeled"
        app:itemTextAppearanceActive="@style/BottomNavText"
        app:itemTextAppearanceInactive="@style/BottomNavText"
        app:menu="@menu/bottom_nav_menu" />

</LinearLayout>
